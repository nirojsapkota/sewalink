.mb-8
  h1.text-3xl.font-bold.text-red-600
    | Active Disputes
  p.text-gray-600
    | Tasks requiring administrative intervention.
.bg-white.rounded-lg.shadow.overflow-hidden
  table.min-w-full.divide-y.divide-gray-200
    thead.bg-gray-50
      tr
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Dispute ID (Task ID)
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Task Title
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Poster
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Tasker
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Budget
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Raised At
        th.px-6.py-3.text-left.text-xs.font-medium.text-gray-500.uppercase.tracking-wider
          | Actions
    tbody.bg-white.divide-y.divide-gray-200
      - @disputes.each do |task|
        tr
          td.px-6.py-4.whitespace-nowrap.text-sm.text-gray-500
            |  #
            = task.id
          td.px-6.py-4.whitespace-nowrap.text-sm.font-medium.text-gray-900
            = task.title.truncate(30)
          td.px-6.py-4.whitespace-nowrap.text-sm.text-gray-500
            = task.user.name || task.user.phone
          td.px-6.py-4.whitespace-nowrap.text-sm.text-gray-500
            = task.tasker&.name || task.tasker&.phone
          td.px-6.py-4.whitespace-nowrap.text-sm.text-gray-500
            = humanized_money_with_symbol task.budget
          td.px-6.py-4.whitespace-nowrap.text-sm.text-gray-500
            = task.updated_at.strftime("%Y-%m-%d %H:%M")
          td.px-6.py-4.whitespace-nowrap.text-sm.font-medium
            = link_to 'Resolve Dispute', admin_dispute_path(task), class: "text-red-600 hover:text-red-900 font-bold"
      - if @disputes.empty?
        tr
          td.px-6.py-10.text-center.text-gray-500[colspan="7"]
            |  No active disputes found. Good job! 
.mt-8
  = paginate @disputes