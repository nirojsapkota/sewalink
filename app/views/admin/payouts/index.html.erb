<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8"><%= t('.admin_payout_management', default: 'Admin Payout Management') %></h1>

  <section class="mb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-4"><%= t('.pending_requests', default: 'Pending Requests') %></h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User (Phone)</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">eSewa ID / Details</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @pending_payouts.any? %>
            <% @pending_payouts.each do |payout| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= payout.user.phone %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold"><%= payout.amount.format %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= payout.payment_details %></td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium flex justify-end gap-2">
                  <%= button_to process_payout_admin_payout_path(payout), method: :patch, class: "bg-green-600 text-white px-3 py-1.5 rounded hover:bg-green-700 transition" do %>
                    <%= t('.mark_processed', default: 'Processed') %>
                  <% end %>
                  <%= button_to reject_payout_admin_payout_path(payout), method: :patch, class: "bg-red-600 text-white px-3 py-1.5 rounded hover:bg-red-700 transition", params: { rejection_reason: "Manual Rejection" } do %>
                    <%= t('.reject', default: 'Reject') %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">No pending payout requests.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <h2 class="text-xl font-bold text-gray-900 mb-4"><%= t('.processed_history', default: 'Processed History') %></h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User (Phone)</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Processed Date</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @processed_payouts.any? %>
            <% @processed_payouts.each do |payout| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= payout.user.phone %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm font-bold"><%= payout.amount.format %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm">
                  <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                    <%= payout.status.humanize %>
                  </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= payout.updated_at.strftime("%b %d, %Y %H:%M") %></td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">No processed payouts yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
