<div class="mb-8 flex justify-between items-center">
  <h1 class="text-3xl font-bold">Task #<%= @task.id %>: <%= @task.title %></h1>
  <div class="flex gap-2">
    <%= link_to 'Back to List', admin_tasks_path, class: "bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300" %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  <div class="md:col-span-2 space-y-8">
    <div class="bg-white p-6 rounded-lg shadow">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Details</h2>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <p class="text-sm text-gray-500">Status</p>
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(@task.status) %>">
            <%= @task.status.humanize %>
          </span>
        </div>
        <div>
          <p class="text-sm text-gray-500">Budget</p>
          <p class="font-medium"><%= humanized_money_with_symbol @task.budget %> (<%= @task.payment_type&.humanize || "Not Set" %>)</p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Category</p>
          <p class="font-medium"><%= @task.category.name_en %></p>
        </div>
        <div>
          <p class="text-sm text-gray-500">Created At</p>
          <p class="font-medium"><%= @task.created_at.strftime("%Y-%m-%d %H:%M") %></p>
        </div>
      </div>
      <div class="mt-4">
        <p class="text-sm text-gray-500">Description</p>
        <p class="mt-1"><%= @task.description %></p>
      </div>
      <div class="mt-4">
        <p class="text-sm text-gray-500">Location</p>
        <p class="mt-1"><%= @task.location %></p>
      </div>
    </div>

    <% if @task.dispute? %>
      <div class="bg-red-50 p-6 rounded-lg border border-red-200 shadow">
        <h2 class="text-xl font-semibold text-red-700 mb-4">Dispute Underway</h2>
        <p class="mb-4">This task is currently in dispute. Platform administrators must resolve it.</p>
        <%= link_to "Go to Dispute Resolution", admin_dispute_path(@task), class: "inline-block bg-red-600 text-white px-6 py-2 rounded hover:bg-red-700" %>
      </div>
    <% end %>

    <div class="bg-white p-6 rounded-lg shadow">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Photos</h2>
      <% if @task.photos.attached? %>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <% @task.photos.each do |photo| %>
            <%= image_tag photo, class: "rounded-lg object-cover h-48 w-full" %>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No photos attached.</p>
      <% end %>
    </div>
  </div>

  <div class="space-y-8">
    <div class="bg-white p-6 rounded-lg shadow">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Participants</h2>
      <div class="space-y-4">
        <div>
          <p class="text-sm text-gray-500">Poster</p>
          <%= link_to admin_user_path(@task.user), class: "flex items-center gap-3 mt-1 hover:bg-gray-50 p-2 rounded" do %>
            <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 font-bold">
              <%= @task.user.name&.first || "U" %>
            </div>
            <div>
              <p class="font-medium text-blue-600"><%= @task.user.name || "Unnamed User" %></p>
              <p class="text-xs text-gray-500"><%= @task.user.phone %></p>
            </div>
          <% end %>
        </div>
        <% if @task.tasker %>
          <div>
            <p class="text-sm text-gray-500">Tasker</p>
            <%= link_to admin_user_path(@task.tasker), class: "flex items-center gap-3 mt-1 hover:bg-gray-50 p-2 rounded" do %>
              <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600 font-bold">
                <%= @task.tasker.name&.first || "T" %>
              </div>
              <div>
                <p class="font-medium text-green-600"><%= @task.tasker.name || "Unnamed Tasker" %></p>
                <p class="text-xs text-gray-500"><%= @task.tasker.phone %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
      <h2 class="text-xl font-semibold mb-4 border-b pb-2">Transactions</h2>
      <% if @task.payment_transactions.any? %>
        <div class="space-y-3">
          <% @task.payment_transactions.each do |tx| %>
            <div class="text-sm border-b pb-2 last:border-0">
              <div class="flex justify-between">
                <span class="font-medium">Payment #<%= tx.id %></span>
                <span class="<%= tx.completed? ? 'text-green-600' : 'text-orange-600' %>"><%= tx.status.humanize %></span>
              </div>
              <p class="text-gray-500 text-xs"><%= tx.created_at.strftime("%b %d, %Y %H:%M") %></p>
              <p class="font-mono text-xs text-gray-400 break-all"><%= tx.transaction_uuid %></p>
              <% if tx.external_ref.present? %>
                <p class="text-xs text-gray-500 mt-1">Ref: <%= tx.external_ref %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No transactions found.</p>
      <% end %>
    </div>
  </div>
</div>
