<div class="mx-auto md:w-2/3 w-full bg-white flex flex-col h-[calc(100vh-80px)]">
  <div class="p-4 border-b flex justify-between items-center bg-gray-50">
    <div>
      <h2 class="text-lg font-bold"><%= @conversation.task.title %></h2>
      <p class="text-xs text-gray-500">
        Chatting with 
        <% if current_user == @conversation.task.user %>
          <%= @conversation.bid.user.phone.presence || "Tasker" %>
        <% else %>
          <%= @conversation.task.user.phone.presence || "Poster" %>
        <% end %>
      </p>
    </div>
    <%= link_to "Back", task_path(@conversation.task), class: "text-blue-600 font-medium" %>
  </div>

  <div id="messages" class="flex-grow overflow-y-auto p-4 space-y-4 bg-white" data-controller="scroll">
    <%= turbo_stream_from @conversation %>
    <%= render @messages %>
  </div>

  <div class="p-4 border-t bg-gray-50">
    <%= form_with(model: [@conversation, @new_message], class: "flex gap-2") do |f| %>
      <%= f.text_field :content, 
          class: "flex-grow rounded-full border-gray-300 px-4 py-2 focus:ring-blue-500 focus:border-blue-500", 
          placeholder: "Type a message...",
          data: { action: "keydown.enter->form#submit" } %>
      <%= f.submit "Send", class: "bg-blue-600 text-white px-6 py-2 rounded-full font-bold cursor-pointer" %>
    <% end %>
  </div>
</div>
