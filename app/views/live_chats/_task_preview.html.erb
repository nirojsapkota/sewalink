<div id="ai_task_preview" class="bg-white rounded-2xl p-6 shadow-sm border border-[#7C3AED]/10">
  <% if task %>
    <div class="mb-4 flex items-center justify-between">
      <span class="bg-[#F5F3FF] text-[#7C3AED] text-xs font-bold px-2 py-1 rounded uppercase tracking-wider">Draft</span>
      <span class="text-[10px] text-[#4C1D95]/40 italic">Syncing...</span>
    </div>

    <h3 class="font-bold text-[#4C1D95] mb-2"><%= task.title.presence || "Untitled Task" %></h3>
    
    <div class="space-y-3">
      <div>
        <label class="text-[10px] uppercase font-bold text-[#4C1D95]/40 block">Description</label>
        <p class="text-sm text-[#4C1D95]/80 line-clamp-3"><%= task.description.presence || "Describe your task..." %></p>
      </div>

      <div class="flex justify-between items-end">
        <div>
          <label class="text-[10px] uppercase font-bold text-[#4C1D95]/40 block">Budget</label>
          <p class="text-lg font-bold text-[#7C3AED]"><%= task.budget > 0 ? humanized_money_with_symbol(task.budget) : "NPR ---" %></p>
        </div>
        <div class="text-right">
          <label class="text-[10px] uppercase font-bold text-[#4C1D95]/40 block">Location</label>
          <p class="text-sm font-medium text-[#4C1D95]/80"><%= task.location.presence || "---" %></p>
        </div>
      </div>
    </div>

    <div class="mt-6 pt-6 border-t border-[#7C3AED]/5">
      <%= link_to "Review & Publish", edit_task_path(task), class: "w-full block text-center bg-[#7C3AED] text-white py-2 rounded-xl font-bold text-sm shadow-sm hover:shadow-md transition" %>
    </div>
  <% else %>
    <div class="py-12 text-center">
      <div class="w-12 h-12 bg-[#F5F3FF] rounded-full mx-auto flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#7C3AED]/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
      </div>
      <p class="text-sm text-[#4C1D95]/40 px-4">Describe your task to the AI to begin drafting your request.</p>
    </div>
  <% end %>
</div>
