.max-w-md.mx-auto.mt-10.p-6.bg-white.rounded-lg.shadow-md
  = render 'profile_info', user: @user
  .flex.flex-col.items-center
    .w-full.space-y-3
      = link_to t('profiles.show.edit'), edit_profile_path, class: "block text-center bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold py-2 px-4 rounded transition-colors"
      = button_to toggle_role_profile_path, method: :patch, class: "w-full bg-[#7C3AED] hover:bg-[#6D28D9] text-white font-semibold py-2 px-4 rounded transition-colors" do
        - target_role = @user.poster? ? 'tasker' : 'poster'
        = t('profiles.roles.toggle', role: t("profiles.roles.#{target_role}"))