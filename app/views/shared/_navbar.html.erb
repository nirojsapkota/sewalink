<nav class="bg-white/80 backdrop-blur-md shadow-sm sticky top-0 z-50 border-b border-[#7C3AED]/5">
  <div class="container mx-auto px-5 py-4 flex items-center justify-between">
    <div class="flex items-center space-x-6">
      <%= link_to root_path, class: "text-2xl font-bold text-[#7C3AED]" do %>
        sewaLink
      <% end %>

      <div class="hidden md:flex space-x-4 items-center">
        <% if user_signed_in? %>
          <% if current_user.poster? %>
            <%= link_to t("dashboards.poster.title"), tasks_path, class: "text-sm font-medium text-[#4C1D95]/70 hover:text-[#7C3AED]" %>
            <%= link_to t("tasks.new.title"), new_task_path, class: "text-sm font-medium text-[#4C1D95]/70 hover:text-[#7C3AED]" %>
          <% else %>
            <%= link_to t("tasks.index.find_tasks"), tasks_path, class: "text-sm font-medium text-[#4C1D95]/70 hover:text-[#7C3AED]" %>
            <%= link_to t("dashboards.tasker.title"), tasker_dashboard_path, class: "text-sm font-medium text-[#4C1D95]/70 hover:text-[#7C3AED]" %>
          <% end %>
          <div class="h-4 w-px bg-[#7C3AED]/20 mx-2"></div>
        <% end %>
        <%= link_to t('language.english'), url_for(locale: :en), class: "text-xs font-semibold text-[#4C1D95]/50 hover:text-[#7C3AED]" %>
        <%= link_to t('language.nepali'), url_for(locale: :ne), class: "text-xs font-semibold text-[#4C1D95]/50 hover:text-[#7C3AED]" %>
      </div>
    </div>

    <div class="flex items-center space-x-4">
      <% if user_signed_in? %>
        <% target_role = current_user.poster? ? 'tasker' : 'poster' %>
        <%= button_to toggle_role_profile_path, method: :patch, class: "flex items-center space-x-2 bg-[#F3E8FF] text-[#7C3AED] px-3 py-1.5 rounded-full text-xs font-bold hover:bg-[#E9D5FF] transition-colors" do %>
          <span class="inline-block w-2 h-2 rounded-full bg-[#22C55E] animate-pulse"></span>
          <span><%= t("profiles.roles.#{current_user.active_role}") %></span>
          <span class="text-[#7C3AED]/40">|</span>
          <span class="text-xs opacity-70"><%= t("profiles.roles.toggle", role: t("profiles.roles.#{target_role}")) %></span>
        <% end %>

        <div class="flex items-center space-x-3">
          <%= link_to profile_path, class: "text-sm font-medium text-[#4C1D95]/70 hover:text-[#7C3AED]" do %>
            <%= t("profiles.show.title") %>
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete, class: "text-sm font-bold text-red-500 hover:text-red-600 transition-colors" do %>
            <%= t("logout") %>
          <% end %>
        </div>
      <% else %>
        <%= link_to t("login"), new_user_session_path, class: "text-sm font-bold text-[#7C3AED] hover:text-[#6D28D9]" %>
        <%= link_to t("register"), new_user_registration_path, class: "bg-[#7C3AED] text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-[#6D28D9] transition-all shadow-md hover:shadow-lg" %>
      <% end %>
    </div>
  </div>

  <div class="md:hidden bg-[#FAF5FF] px-5 py-2 flex justify-center space-x-6 border-t border-[#7C3AED]/5">
    <%= link_to t('language.english'), url_for(locale: :en), class: "text-xs font-bold text-[#4C1D95]/40" %>
    <%= link_to t('language.nepali'), url_for(locale: :ne), class: "text-xs font-bold text-[#4C1D95]/40" %>
  </div>
</nav>
