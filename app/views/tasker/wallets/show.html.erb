<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8"><%= t('.wallet_title', default: 'My Wallet') %></h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider"><%= t('.current_balance', default: 'Current Balance') %></h3>
      <p class="mt-2 text-3xl font-bold text-[#7C3AED]"><%= @balance.format %></p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
      <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wider"><%= t('.potential_income', default: 'Potential Income (Pending Bids)') %></h3>
      <p class="mt-2 text-2xl font-semibold text-gray-700">Rs. <%= @pending_bids_total %></p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col justify-center">
      <%= link_to t('.request_payout', default: 'Request Payout'), '#payout-form', class: "block w-full text-center py-3 px-4 bg-[#7C3AED] text-white rounded-lg font-bold hover:bg-[#6D28D9] transition" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-lg font-bold text-gray-900"><%= t('.recent_transactions', default: 'Recent Transactions') %></h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('.date', default: 'Date') %></th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('.type', default: 'Type') %></th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"><%= t('.amount', default: 'Amount') %></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @transactions.any? %>
            <% @transactions.each do |tx| %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= tx.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900"><%= tx.code.to_s.humanize %></td>
                <td class="px-6 py-4 whitespace-nowrap text-sm text-right font-medium <%= tx.amount > 0 ? 'text-green-600' : 'text-red-600' %>">
                  <%= tx.amount.format %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="3" class="px-6 py-8 text-center text-sm text-gray-500"><%= t('.no_transactions', default: 'No transactions found.') %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div id="payout-form" class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
    <h2 class="text-lg font-bold text-gray-900 mb-4"><%= t('.payout_request', default: 'Submit Payout Request') %></h2>
    
    <% if @balance >= Money.new(500_00, 'NPR') %>
      <%= form_with(model: @payout_request, url: tasker_payout_requests_path, local: true, class: "space-y-4") do |f| %>
        <div class="flex flex-col">
          <%= f.label :amount, t('.amount_to_withdraw', default: 'Amount (NPR)'), class: "text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.number_field :amount, min: 500, max: @balance.to_f, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-[#7C3AED] focus:ring-[#7C3AED]", placeholder: "Minimum 500" %>
          <p class="text-xs text-gray-500 mt-1"><%= t('.min_amount_help', default: 'Minimum withdrawal: Rs. 500') %></p>
        </div>

        <div class="flex flex-col">
          <%= f.label :payment_details, t('.eSewa_ID', default: 'eSewa ID (Phone Number)'), class: "text-sm font-semibold text-gray-700 mb-1" %>
          <%= f.text_field :payment_details, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-[#7C3AED] focus:ring-[#7C3AED]", placeholder: "e.g. 98XXXXXXXX" %>
        </div>

        <%= f.submit t('.submit_request', default: 'Submit Withdrawal Request'), class: "w-full rounded-lg py-3 px-6 bg-[#7C3AED] text-white font-bold hover:bg-[#6D28D9] transition" %>
      <% end %>
    <% else %>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded-r-lg">
        <p class="text-sm text-yellow-700">
          <%= t('.insufficient_balance_msg', default: 'You need at least Rs. 500 in your wallet to request a payout.') %>
        </p>
      </div>
    <% end %>
  </div>
</div>
