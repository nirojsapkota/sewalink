<div id="<%= dom_id task %>">
  <div class="mb-5">
    <div class="flex justify-between items-start">
      <div>
        <h2 class="text-3xl font-bold"><%= task.title %></h2>
        <p class="text-gray-600">
          <%= I18n.locale == :ne ? task.category.name_ne : task.category.name_en %>
        </p>
      </div>
      <div class="text-right">
        <span class="inline-block px-3 py-1 text-sm font-semibold rounded-full <%= task.open? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
          <%= t("tasks.statuses.#{task.status}") %>
        </span>
        <p class="text-xl font-bold text-blue-600 mt-1">Rs. <%= number_with_delimiter(task.budget) %></p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div>
      <h3 class="text-lg font-semibold mb-2"><%= t('.description', default: 'Description') %></h3>
      <p class="text-gray-700 whitespace-pre-wrap"><%= task.description %></p>

      <h3 class="text-lg font-semibold mt-6 mb-2"><%= t('.location', default: 'Location') %></h3>
      <p class="text-gray-700"><%= task.location %></p>
    </div>

    <div>
      <% if task.photos.attached? %>
        <h3 class="text-lg font-semibold mb-2"><%= t('.photos', default: 'Photos') %></h3>
        <div class="grid grid-cols-2 gap-2">
          <% task.photos.each do |photo| %>
            <%= image_tag photo.representation(resize_to_limit: [400, 400]), class: "rounded-lg object-cover w-full h-48" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
