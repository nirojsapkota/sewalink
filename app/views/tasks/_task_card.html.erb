<div class="border rounded-xl p-5 hover:shadow-lg transition-shadow bg-white relative">
  <div class="flex justify-between items-start mb-3">
    <span class="inline-block px-2 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">
      <%= I18n.locale == :ne ? task.category.name_ne : task.category.name_en %>
    </span>
    <p class="font-bold text-green-600 text-lg">Rs. <%= number_with_delimiter(task.budget) %></p>
  </div>

  <h2 class="text-xl font-bold mb-1 truncate"><%= task.title %></h2>
  <p class="text-gray-600 text-sm line-clamp-2 mb-4"><%= task.description %></p>

  <div class="flex items-center text-xs text-gray-400 mb-4">
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
    </svg>
    <%= task.location %>
    <% if defined?(current_location) && current_location.present? %>
       • <%= task.distance_to(current_location).round(1) %> km away
    <% end %>
  </div>

  <% if task.photos.attached? %>
    <div class="flex gap-2 mb-4 overflow-x-auto">
      <% task.photos.limit(3).each do |photo| %>
        <%= image_tag photo.representation(resize_to_limit: [100, 100]), class: "w-16 h-16 rounded object-cover" %>
      <% end %>
    </div>
  <% end %>

  <%= link_to t('.bid_now', default: 'Details & Bid'), task, class: "block text-center rounded-lg py-2 px-4 bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors" %>
</div>
