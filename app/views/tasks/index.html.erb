<div class="mx-auto w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 text-green-500 font-medium rounded-lg inline-block mb-5" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="font-bold text-4xl">
      <%= current_user.tasker? ? t('.discovery_title', default: 'Find Work') : t('.dashboard_title', default: 'My Tasks') %>
    </h1>
    <% if current_user.poster? %>
      <%= link_to t('.new_task', default: 'Post New Task'), new_task_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white block font-medium" %>
    <% end %>
  </div>

  <% if current_user.tasker? %>
    <%= render "filter_form" %>
  <% end %>

  <%= turbo_frame_tag "tasks" do %>
    <div id="tasks-list" class="min-w-full">
      <% if @tasks.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @tasks.each do |task| %>
            <% if current_user.tasker? %>
              <%= render "task_card", task: task %>
            <% else %>
              <%= render "task_summary", task: task %>
            <% end %>
          <% end %>
        </div>
        <div class="mt-10">
          <%= paginate @tasks %>
        </div>
      <% else %>
        <div class="text-center py-20 bg-gray-50 rounded-xl border-2 border-dashed border-gray-200">
          <h3 class="text-xl font-medium text-gray-600 mb-2">
            <%= current_user.tasker? ? t('.no_available_tasks', default: 'No tasks found.') : t('.no_my_tasks', default: 'You haven\'t posted any tasks yet.') %>
          </h3>
          <p class="text-gray-400 mb-6">
            <%= current_user.tasker? ? t('.try_adjusting_filters', default: 'Try adjusting your filters to see more results.') : t('.start_posting', default: 'Post your first task and get bids from local experts!') %>
          </p>
          <% if current_user.poster? %>
            <%= link_to t('.new_task', default: 'Post New Task'), new_task_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white inline-block font-medium" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
